{
  "name": "Python Dev",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy",
        "GitHub.copilot",
        "ms-vscode.makefile-tools",
        "mongodb.mongodb-vscode"
      ]
    }
  },
  "postCreateCommand": "pip install -r requirements.txt"
}